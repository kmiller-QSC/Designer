PluginInfo =
  {
    Name = "sACN Transmit",
    Version = "1.0",
    Id = "3013f7f6-d308-4442-9a06-15708570734c",
    Author = "K. Rhodus // Q-SYS",
    Description = "sACN Transmitter for Q-SYS",
    ShowDebug = false,
    BuildVersion = "5"
  };

function GetColor(props)
  return { 255,255,255}
end
  
function GetPrettyName(props)
  return PluginInfo.Name
end

function GetProperties()
  props = {}

  table.insert(props, {
    Name = "Number of Channels",
    Type = "integer",
    Value = 10,
    Min = 2,
    Max = 512,
    })

  table.insert(props, {
    Name = "Debug Print",
    Type = "enum",
    Choices = {"None", "Tx", "Function Calls", "All"},
    Value = "None"
  })



  return props
end

function RectifyProperties(props)
  return props
end

function GetControls(props)
  local ctrl = {};
	
  table.insert(ctrl,{
    Name = "DMX_In",
    ControlType = "Knob",
    ControlUnit = "Integer",
    Max = 255,
    Min = 0,
    UserPin = false,
    PinStyle = "Both",
    Count = props["Number of Channels"].Value,
  })

  table.insert(ctrl,{
    Name = "Unicast",
    ControlType = "Button",
    ButtonType = "Toggle",
    UserPin = true,
    PinStyle = "Both",
  })

  table.insert(ctrl,{
    Name = "IP_Address",
    ControlType = "Text",
    UserPin = true,
    PinStyle = "Both",
  })

  table.insert(ctrl,{
    Name = "Universe",
    ControlType = "Knob",
    ControlUnit = "Integer",
    Max = 63999,
    Min = 1,
    UserPin = true,
    PinStyle = "Both",
  })

  table.insert(ctrl,{
    Name = "Status",
    ControlType = "Indicator",
    IndicatorType = "Status",
    UserPin = true,
    PinStyle = "Output",
  })

  table.insert(ctrl,{
    Name = "Priority",
    ControlType = "Knob",
    ControlUnit = "Integer",
    Max = 200,
    Min = 1,
    UserPin = true,
    PinStyle = "Both",
  })

  table.insert(ctrl,{
    Name = "Transmit",
    ControlType = "Button",
    ButtonType = "Toggle",
    UserPin = true,
    PinStyle = "Both",
  })

  table.insert(ctrl,{
    Name = "Interface",
    ControlType = "Text",
    UserPin = true,
    PinStyle = "Both",
  })

  return ctrl;
end

