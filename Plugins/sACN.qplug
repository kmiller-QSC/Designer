  -- [[ DO NOT MODIFY BELOW THIS POINT ]] --Sorry I did. 

  SACN_FORMAT = bitstring.compile(''

  --[[ Root Layer ]] --
  .. '16:int, '  -- Preamble Size
  .. '16:int, '  -- Postamble Size
  .. '12:bin, '  -- ACN Packet identifier
  .. '4:int,  '  -- Flags
  .. '12:int, '  -- Length
  .. '16:int, 16:int, '  -- RLP Data 1.31 PDU Identifier
  .. '16:bin, '  -- Sender CID
  
  --[[ E1.31 Framing Layer ]]--
  .. '4:int,  '  -- Flags
  .. '12:int, '  -- Length
  .. '16:int, 16:int, '  -- DMP PDU Identifier
  .. '64:bin, '  -- Source name
  .. '8:int,  '  -- Priority
  .. '16:int, '  -- Reserved
  .. '8:int,  '  -- Sequence number
  .. '1:int,  '  -- Preview_Data
  .. '1:int,  '  -- Stream_Terminated
  .. '6:int,  '  -- Misc flags
  .. '16:int, '  -- DMX Universe number
  
  --[[ DMP Layer ]]--
  .. '4:int,  '  -- Flags
  .. '12:int, '  -- PDU length
  .. '8:int,  '  -- DMP Set Property Message PDU Identifier
  .. '8:int,  '  -- Address and data type
  .. '16:int, '  -- First property address
  .. '16:int, '  -- Address increment
  .. '16:int, '  -- Property value count
  
  );

  NUM_CHANNELS = Properties["Number of Channels"].Value;
  SEQ_NUMBER = 1;
  DESIGN_CODE = Design.GetStatus().DesignCode;
  DESIGN_NAME = Design.GetStatus().DesignName;




  -- sACN Packet Formatter
  function sendPacket()
    if DebugFunction then print("sendPacket() called") end
    local dmx_ch_blob = '';
    for i=1,NUM_CHANNELS do
      local inputValue = Controls.DMX_In[i].Value;
      if(inputValue < 0) then inputValue = 0; end;
      if(inputValue > 255) then inputValue = 255; end;
      dmx_ch_blob = dmx_ch_blob .. string.char(inputValue);
    end;
    local sACNpacket = bitstring.pack(SACN_FORMAT,

    --[[ Root Layer ]] --
      0x0010,            -- Preamble Size
      0x0000,            -- Postamble Size
      'ASC-E1.17\0\0\0', -- ACN Packet identifier
      0x07,              -- Flags
      NUM_CHANNELS + 0x6E ,    -- Length
      0x00, 0x04,              -- RLP PDU Identifier
      DESIGN_CODE .. string.rep('\0', 16-#DESIGN_CODE), -- Sender CID
    
    --[[ E1.31 Framing Layer ]]--
      0x07  ,                -- Flags
      NUM_CHANNELS + 0x58 ,  -- Length
      0x00, 0x02,                 -- DMP PDU Identifier
      'Q-SYS sACN Plugin in "' .. DESIGN_NAME .. '"' .. string.rep('\0', 41-#DESIGN_NAME) , -- Source name
      string.format("0x%X", Controls.Priority.Value) ,                 -- Priority
      0x00,                  -- Reserved
      SEQ_NUMBER ,           -- Sequence number
      0x00 ,                 -- Preview_Data
      0x00 ,                 -- Stream_Terminated
      0x00 ,                 -- Misc flags
      Controls.Universe.Value ,         -- DMX Universe number
    
    --[[ DMP Layer ]]--
      0x07  ,                -- Flags
      NUM_CHANNELS + 0x0B ,  -- PDU length
      0x02  ,                -- DMP Set Property Message PDU Identifier
      0xA1  ,                -- Address and data type
      0x0000,               -- First property address
      0x0001 ,               -- Address increment
      NUM_CHANNELS + 0x01    -- Property value count
    
    ) .. '\0' .. dmx_ch_blob;

    if IP_Flag == true or not Controls.Unicast.Boolean then 
      UDP_SOCKET:Send(Controls.Unicast.Boolean and Controls.IP_Address.String or MULTICAST_IP, 5568, sACNpacket);
      if DebugTx then print("[TX]:"..bitstring.hexstream(sACNpacket)) end
    else
      Controls.Status.Value = 2
      Controls.Status.String = "No IP Set - Transmit Stopped"
      Controls.Transmit.Boolean = false
      Controls.Transmit.Legend = "Stopped"
      SendTimer:Stop()
    end
    SEQ_NUMBER = (SEQ_NUMBER + 1) % 0xFF;
    
  end;

  SendTimer = Timer.New();
  SendTimer.EventHandler = sendPacket;


  -----------------------------------------------------------------------------------------------------------------------------------------
  --      Transmit Functions      --
  ----------------------------------------------------------------------------------------------------------------------------------------

  Controls.Transmit.EventHandler = function(ctl)
    if ctl.Boolean then 
      if Controls.Interface.String ~= "" and Controls.IP_Address.String ~= "" then 
        SendTimer:Start(0.03)
        ctl.Legend = "Transmitting"
        Controls.Status.Value = 0
        Controls.Status.String = "Transmitting sACN"
      else
        ctl.Boolean = false
        Controls.Status.Value = 2
        Controls.Status.String = "Interface / Destination Not Set"
      end
    else 
      SendTimer:Stop()
      ctl.Legend = "Stopped"
      Controls.Status.Value = 0
      Controls.Status.String = "Stopped"
    end
  end

  if Controls.Transmit.Boolean then 
    SendTimer:Start(0.03)
    Controls.Transmit.Legend = "Transmitting"
    Controls.Status.Value = 0
    Controls.Status.String = "Transmitting sACN"
  else
    Controls.Transmit.Legend = "Stopped"
    Controls.Status.Value = 0
    Controls.Status.String = "Stopped"
  end
end