  -----------------------------------------------------------------------------------------------------------------------------------------
  --      Script Setup      --
  ----------------------------------------------------------------------------------------------------------------------------------------
  -- Debugging level
  DebugTx,DebugFunction = false, false
  --DebugPrint = Properties["Debug Print"].Value

  if DebugPrint == "Tx" then
    DebugTx = true
  elseif DebugPrint == "Function Calls" then
    DebugFunction = true
  elseif DebugPrint == "All" then
    DebugTx, DebugFunction = true, true
  end

  json = require("rapidjson")
  -----------------------------------------------------------------------------------------------------------------------------------------
  --      IP Address Functions      --
  ----------------------------------------------------------------------------------------------------------------------------------------
  --Calculate Multicast IP Address
  function CalcMulticast()
    if DebugFunction then print("CalcMulticast() called") end
    local highUniverseByte = math.floor(Controls.Universe.Value / 256)
    local lowUniverseByte = math.floor(Controls.Universe.Value % 256)
    MULTICAST_IP = ('239.255.' .. highUniverseByte .. '.' .. lowUniverseByte);
    if not Controls.Unicast.Boolean then 
      Controls.IP_Address.String = MULTICAST_IP
    end
  end

  CalcMulticast()   --Run at Startup
  Controls.Universe.EventHandler = CalcMulticast    --Run when Universe Changes

  --Disable IP Address Field
  Controls.Unicast.EventHandler = function(ctl)
    Controls.IP_Address.IsDisabled = not ctl.Boolean

    SendTimer:Stop()
    Controls.Transmit.Boolean = false
    Controls.Transmit.Legend = "Stopped"
    
    if ctl.Boolean then 
      ctl.Legend = "Unicast"
      if prevIPAddress ~= nil then
        Controls.IP_Address.String = prevIPAddress
      else
        Controls.IP_Address.String = ""
        IP_Flag = false
      end
    else
      ctl.Legend = "Multicast"
      prevIPAddress = Controls.IP_Address.String
      Controls.IP_Address.String = MULTICAST_IP
    end 
  end

  Controls.IP_Address.IsDisabled = not Controls.Unicast.Boolean
  Controls.Unicast.Legend = Controls.Unicast.Boolean and "Unicast" or "Multicast"

  --IP Address Check
  function isValidIP(ip)
      if DebugFunction then print("isValidIP() called") end
      -- Check if the IP matches the IPv4 pattern
      if not ip:match("^%d+%.%d+%.%d+%.%d+$") then
            Controls.Status.Value = 1
            Controls.Status.String = "Not Valid IP Address"

          return false
      end

      -- Split the IP into its four octets
      local octets = {ip:match("(%d+)%.(%d+)%.(%d+)%.(%d+)")}
      if #octets ~= 4 then
            Controls.Status.Value = 1
            Controls.Status.String = "Not Valid IP Address"
          return false
      end

      -- Check if each octet is within the valid range (0-255)
      for _, octet in ipairs(octets) do
          local num = tonumber(octet)
          if not num or num < 0 or num > 255 then
              Controls.Status.Value = 1
              Controls.Status.String = "Not Valid IP Address"
              return false
          end
      end

      Controls.Status.Value = 0
      Controls.Status.String = "Valid IP Address"
      return true

  end

  Controls.IP_Address.EventHandler = function(ctl)
    IP_Flag = isValidIP(ctl.String)

  end
    
  IP_Flag = isValidIP(Controls.IP_Address.String)


 -----------------------------------------------------------------------------------------------------------------------------------------
  --      UDP Functions      --
  ----------------------------------------------------------------------------------------------------------------------------------------
  UDP_SOCKET = UdpSocket.New()
  
  function OpenSocket()
    if interfaces[Controls.Interface.String] ~= nil then
      UDP_SOCKET:Open(interfaces[Controls.Interface.String])
      Controls.Status.Value = 0
      Controls.Status.String = "Opening Socket on ".. interfaces[Controls.Interface.String]
    else
      Controls.Status.Value = 2
      Controls.Status.String = Controls.Interface.String .. " does not exist"
    end
  end 
  
  --Build table of UDP Interfaces
  function getInterfaces()
    if DebugFunction then print("getInterfaces() called") end
    local temp = Network.Interfaces()
    interfaces = {}
    for _,ctl in ipairs(temp) do
      print(ctl.Interface)
      interfaces[ctl.Interface] = ctl.Address
      table.insert(interfaces, ctl.Interface)
    end
    Controls.Interface.Choices = interfaces
  end

  getInterfaces()


  Controls.Interface.EventHandler = function()
    SendTimer:Stop()
    Controls.Transmit.Legend = "Stopped"
    Controls.Transmit.Boolean = false
    Controls.Status.Value = 0
    Controls.Status.String = "Stopped"
    UDP_SOCKET:Close()
    OpenSocket()
  end

  OpenSocket()

  -- [[ ORIGIONAL CODE FROM Locimation with modifications ]] --
