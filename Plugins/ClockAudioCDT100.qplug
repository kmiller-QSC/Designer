    table.insert(graphics,{Type = "Text",Text = "Local NIC",WordWrap = true,TextSize = 14,HTextAlign = "Right",IsBold = true,Color = White,Position = { 301, 34 },Size = { 38, 32 }})
    table.insert(graphics,{Type = "Text",Text = "Recv Port",WordWrap = true,TextSize = 14,HTextAlign = "Right",IsBold = true,Color = White,Position = { 508, 34 },Size = { 33, 32 }})
    table.insert(graphics,{Type = "Text",Text = "Local IP",WordWrap = true,TextSize = 14,HTextAlign = "Right",IsBold = true,Color = White,Position = { 301, 76 },Size = { 38, 32 }})
