--********************************************************************************
--* Project Constants
--********************************************************************************
Color = {
  Orange =   { 242, 89,  0   },
  White  =   { 255, 255, 255 },
  Black  =   { 0,   0,   0,  },
  Bkgnd  =   { 175, 175, 175 },
  CtlBkgnd = { 80,  80,  80  },
  LtGry  =   { 99,  99,  99  },
  Red    =   { 255, 0,   0   },
  DkRed  =   { 188, 0,   29  },
  LtBlue =   { 141, 207, 244 },
  Green  =   { 0,   255, 0   },
  Yellow =   { 255, 255, 0   },
  QSC_PP =   { 242, 137, 174 },
  Line =     { 0,   134, 237 },
  QSC_Inv  = { 254, 248, 134 },
  QSC_Mute = { 223, 0,   36  },
  QSC_Gain = { 124, 155, 207 },
  QSC_Mtr  = { 0,   159, 60  },
  Volume   = { 212, 236, 255 },
}


--********************************************************************************
--* Property Constants (if any)
--********************************************************************************
MODELS = {
  "MK1",
  "MK2",
  "MK3"
}

PROP_MODEL = "Model"

--********************************************************************************
--* Page Constants (if any)
--********************************************************************************


PluginInfo = {
    Name = "Enterprise Manager~Clock Audio~CDT100 v3.6",
    Version = "3.6",
    BuildVersion = "3.6.0.0",
    Id = "91b57fdec7bd41fb9b9741210ad2a1f3",
    Description = "Clock Audio CDT100 Mk1, Mk2, and Mk3 with Brightness",
    Manufacturer = "ClockAudio",
    Author = "QSC",
    Type = Reflect and Reflect.Types.AudioIO or 0,
    IsManaged = true,
}


--********************************************************************************
--* Function: GetColor(props)
--********************************************************************************
function GetColor(props)
  return { 0, 127, 255 }
end


--********************************************************************************
--* Function: GetPrettyName(props)
--********************************************************************************
function GetPrettyName(props)
  return "ClockAudio CDT100\rv" ..PluginInfo.BuildVersion
end


--********************************************************************************
--* Function: GetProperties
--********************************************************************************
function GetProperties()
  props = {}
  table.insert(props,{Name = PROP_MODEL,Type = "enum",Choices = MODELS,Value = MODELS[1]})
  table.insert(props,{
    Name    = "Debug Print",
    Type    = "enum",
    Choices = {"None", "Tx/Rx", "Tx", "Rx", "Function Calls", "All"},
    Value   = "None"})
  return props
end

--********************************************************************************
--* Function: RectifyProperties
--********************************************************************************
function RectifyProperties(props)
  if props.plugin_show_debug.Value == false then 
    props["Debug Print"].IsHidden = true 
  end
  return props
end

--********************************************************************************
--* Function: GetModel(props)
--********************************************************************************
function GetModel(props)
  return props
end


--********************************************************************************
--* Function: GetControls(props)
--********************************************************************************
function GetControls(props)
  ctrls = {}
  local CDType = props["Model"].Value
  table.insert(ctrls,{Name = "IPAddress",ControlType = "Text",UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "NIC",ControlType = "Text",UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "LocalIP",ControlType = "Text",UserPin = true,PinStyle = "Output",Count = 1})
  table.insert(ctrls,{Name = "ReceivePort",ControlType = "Knob",ControlUnit = "Integer",Min = 0,Max = 65535,Count = 1})
  table.insert(ctrls,{Name = "DeviceID",ControlType = "Text",UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "IDDevice",ControlType = "Button",ButtonType = "Toggle",UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "Status",ControlType = "Indicator",IndicatorType = Reflect and "StatusGP" or "Status",UserPin = true,PinStyle = "Output",Count = 1})
  table.insert(ctrls,{Name = "PhantomPower",ControlType = "Button",ButtonType = "Toggle",UserPin = true,PinStyle = "Both",Count = 4})
  table.insert(ctrls,{Name = "ARMC",ControlType = "Button",ButtonType = "Toggle",UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "GreenState",ControlType = "Button",ButtonType = "Toggle",UserPin = true,PinStyle = "Both",Count = 4})
  table.insert(ctrls,{Name = "GreenBrightness",ControlType = "Knob",ControlUnit = "Integer",Min = 0,Max = ((CDType == MODELS[1]) and 10 or 255),UserPin = true,PinStyle = "Both",Count = 4})
  table.insert(ctrls,{Name = "GreenBrightnessInput",ControlType = "Knob",ControlUnit = "Integer",Min = 0,Max = ((CDType == MODELS[1]) and 10 or 255),UserPin = true,PinStyle = "Both",Count = 4})
  table.insert(ctrls,{Name = "RedState",ControlType = "Button",ButtonType = "Toggle",UserPin = true,PinStyle = "Both",Count = 4})
  table.insert(ctrls,{Name = "RedBrightness",ControlType = "Knob",ControlUnit = "Integer",Min = 0,Max = ((CDType == MODELS[1]) and 10 or 255),UserPin = true,PinStyle = "Both",Count = 4})
  table.insert(ctrls,{Name = "RedBrightnessInput",ControlType = "Knob",ControlUnit = "Integer",Min = 0,Max = ((CDType == MODELS[1]) and 10 or 255),UserPin = true,PinStyle = "Both",Count = 4})
  table.insert(ctrls,{Name = "GlobalGreenState",ControlType = "Button",ButtonType = "Toggle",UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "GlobalGreenBrightness",ControlType = "Knob",ControlUnit = "Integer",Min = 0,Max = ((CDType == MODELS[1]) and 10 or 255),UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "GlobalGreenBrightnessInput",ControlType = "Knob",ControlUnit = "Integer",Min = 0,Max = ((CDType == MODELS[1]) and 10 or 255),UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "GlobalRedState",ControlType = "Button",ButtonType = "Toggle",UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "GlobalRedBrightness",ControlType = "Knob",ControlUnit = "Integer",Min = 0,Max = ((CDType == MODELS[1]) and 10 or 255),UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "GlobalRedBrightnessInput",ControlType = "Knob",ControlUnit = "Integer",Min = 0,Max = ((CDType == MODELS[1]) and 10 or 255),UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "ButtonState",ControlType = "Button",ButtonType = "Toggle",UserPin = true,PinStyle = "Output",Count = (CDType == MODELS[1]) and 4 or 12})
  table.insert(ctrls,{Name = "ButtonPreview",ControlType = "Indicator",IndicatorType = "Led",UserPin = true,PinStyle = "Output",Count = 4})
  table.insert(ctrls,{Name = "LoadPreset",ControlType = "Button",ButtonType = "Trigger",UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "SavePreset",ControlType = "Button",ButtonType = "Momentary",UserPin = true,PinStyle = "Both",Count = 1})
  table.insert(ctrls,{Name = "FirmwareVersion",ControlType = "Text",UserPin = true,PinStyle = "Output",Count = 1})
  table.insert(ctrls,{Name = "BootVersion",ControlType = "Text",UserPin = true,PinStyle = "Output",Count = 1})
  
  if CDType ~= MODELS[1] then
    table.insert(ctrls,{Name = "BlueState",ControlType="Button",ButtonType="Toggle",UserPin=true,PinStyle="Both",Count=4})
    table.insert(ctrls,{Name = "BlueBrightness",ControlType="Knob",ControlUnit="Integer",Min=0,Max=255,UserPin=true,PinStyle="Both",Count=4})
    table.insert(ctrls,{Name = "BlueBrightnessInput",ControlType="Knob",ControlUnit="Integer",Min=0,Max=255,UserPin=true,PinStyle="Both",Count=4})
    table.insert(ctrls,{Name = "GlobalBlueState",ControlType="Button",ButtonType="Toggle",UserPin=true,PinStyle="Both",Count=1})
    table.insert(ctrls,{Name = "GlobalBlueBrightness",ControlType="Knob",ControlUnit="Integer",Min=0,Max=255,UserPin=true,PinStyle="Both",Count=1})
    table.insert(ctrls,{Name = "GlobalBlueBrightnessInput",ControlType="Knob",ControlUnit="Integer",Min=0,Max=255,UserPin=true,PinStyle="Both",Count=1})
  end
  return ctrls
end


--********************************************************************************
--* Function: GetControlLayout(props)
--********************************************************************************
function GetControlLayout(props)
  layout   = {}
  graphics = {}
  local CDType = props["Model"].Value
  local White = { 255, 255, 255 }
  local LtGray = { 204, 204, 204 }
  local Gray = { 105, 105, 105 }
  local BtnGray = { 102, 102, 102 }
  local GroupFill = { 86, 122, 138 }
  local LtBlue = { 165, 216, 246 }
  local BtnBlue = { 0, 181, 239 }
  local BtnLtBlue = { 0, 174, 237 }
  local BtnDkBlue = { 0, 43, 64 }
  local BtnGray = { 102, 102, 102 }
  local LEDGrn = { 128, 255, 0 }
  local LEDRed = { 255, 0, 36 }
  local LEDBlue = { 0, 131, 255 } 
  local LEDAmb = { 248, 244, 0 }
  local lc = { "PD94bWwgdmVyc2lvbj0iMS4wIiBlbmNvZGluZz0idXRmLTgiPz48IURPQ1RZUEUgc3ZnIFBVQkxJQyAiLS8vVzNDLy9EVEQgU1ZHIDEuMS8vRU4iICJodHRwOi8vd3d3LnczLm9yZy9HcmFwaGljcy9TVkcvMS4xL0RURC9zdmcxMS5kdGQiPjxzdmcgdmVyc2lvbj0iMS4xIiB"}
  local l = {
    ca  = lc[1].."",
    dt  = "",
    cdt = "",
    fc  = "",
    mk2 = ""
  }
  
  if CDType == MODELS[1] then
    -- graphics for MK1 controls
    layout["IPAddress"] = {PrettyName = "IP Address",Style = "Text",Color = LtBlue,Position = { 63, 34 },Size = { 131, 32 },TextFontSize = 18}
    layout["NIC"] = {PrettyName = "Local NIC",Style = "ComboBox",Color = LtBlue,Position = { 339, 34 },Size = { 159, 32 },TextFontSize = 20}
    layout["ReceivePort"] = {PrettyName = "Receive Port",Style = "Textbox",TextBoxStyle = "Normal",TextFontSize = 20,Position = { 541, 34 },Size = { 69, 32 }}
    layout["LocalIP"] = {PrettyName = "Local IP",Style = "Text",IsReadOnly=true,Color = LtBlue,Position = { 339, 76 },Size = { 131, 32 },TextFontSize = 18}
    layout["DeviceID"] = {PrettyName = "Switch Address",Style = "Text",IsReadOnly = true,Color = LtBlue,Position = { 63, 118 },Size = { 36, 32 },TextFontSize = 30}
    layout["IDDevice"] = {PrettyName = "ID",Legend = "ID",TextFontSize = 16,IsBold = true,Style = "Button",ButtonStyle = "Toggle",Color = BtnBlue,OffColor = BtnGray,UnlinkOffColor = true,Position = { 114, 118 },Size = { 71, 32 },Radius = 2,Margin = 2}
    layout["Status"] = {PrettyName = "Status",Style = "Text",Position = { 242, 118 },Size = { 368, 32 },TextFontSize = 16}
