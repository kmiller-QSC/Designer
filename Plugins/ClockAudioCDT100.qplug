    table.insert(graphics,{Type = "Svg",Image = l.ca,Position = { 29, 6 },Size = { 265, 24 }})
    -- CDT100 Logo
    table.insert(graphics,{Type = "Svg",Image = l.cdt,Position = { 310, 10 },Size = { 143, 15 }})
