    table.insert(graphics,{Type = "Text",Text = "Boot:",HTextAlign = "Left",TextSize = 16,Color = White,Position = { 17, 673 },Size = { 76, 20 }, TextColor = White})
    table.insert(graphics,{Type = "Text",Text = "Firmware:",HTextAlign = "Left",TextSize = 16,Color = White,Position = { 17, 693 },Size = { 76, 20 }, TextColor = White})
    table.insert(graphics,{Type = "Header",Text = "Plugin",TextSize = 18,Color = White,Position = { 491, 654 },Size = { 122, 19 }})
    table.insert(graphics,{Type = "Text",Text = "Version:",HTextAlign = "Left",TextSize = 16,Color = White,Position = { 489, 678 },Size = { 61, 20 }})
