    table.insert(graphics,{Type = "Text",Text = "Firmware:",HTextAlign = "Left",TextSize = 16,Color = White,Position = { 105, 693 },Size = { 76, 20 }})
    table.insert(graphics,{Type = "Header",Text = "Plugin",TextSize = 18,Color = White,Position = { 704, 654 },Size = { 122, 19 }})
    table.insert(graphics,{Type = "Text",Text = "Version:",HTextAlign = "Left",TextSize = 16,Color = White,Position = { 704, 678 },Size = { 61, 20 }})
    table.insert(graphics,{Type = "Text",Text = string.match(PluginInfo.Version,"(%d.%d)"),HTextAlign = "Right",IsBold = true,TextSize = 16,Color = White,Position = { 756, 678 },Size = { 61, 20 }})
    -- Channel graphics
    for i=1,3 do
      -- Phantom power partitions
      table.insert(graphics,{Type = "GroupBox",Fill = White,StrokeWidth = 0,Position = { 294+(i-1)*97, 201 },Size = { 1, 49 }})
      -- TS partitions
      table.insert(graphics,{Type = "GroupBox",Fill = White,StrokeWidth = 0,Position = { 286+(i-1)*181, 399 },Size = { 1, 239 }})
    end
    for i=1,4 do
      -- Phantom power channel text
      table.insert(graphics,{Type = "Text",Text = "Channel "..i,TextSize = 18,Color = White,Position = { 195+(i-1)*98, 178 },Size = { 98, 23 }})
      -- TS channel text
      table.insert(graphics,{Type = "Text",Text = "Channel "..i,TextSize = 18,Color = White,Position = { 105+(i-1)*181, 400 },Size = { 181, 23 }})
    end
  end
  
  -- common graphics
  table.insert(graphics,{Type = "Text",Text = "Global LED Color",WordWrap = true,HTextAlign = "Right",TextSize = 16,IsBold = true,Color = White,Position = { 17, 289 },Size = { 85, 45 }})
  table.insert(graphics,{Type = "Text",Text = "Global Brightness",WordWrap = true,HTextAlign = "Right",TextSize = 16,IsBold = true,Color = White,Position = { 17, 352 },Size = { 85, 32 }})
  table.insert(graphics,{Type = "Text",Text = "LED Color",WordWrap = true,HTextAlign = "Right",TextSize = 16,IsBold = true,Color = White,Position = { 55, 434 },Size = { 47, 45 }})
  table.insert(graphics,{Type = "Text",Text = "Brightness",WordWrap = true,HTextAlign = "Right",TextSize = 16,IsBold = true,Color = White,Position = { 17, 503 },Size = { 85, 28 }})
  table.insert(graphics,{Type = "Text",Text = "Switch State",WordWrap = true,HTextAlign = "Right",TextSize = 16,IsBold = true,Color = White,Position = { 4, 545 },Size = { 98, 37 }})
  table.insert(graphics,{Type = "Text",Text = "Button Preview",WordWrap = true,HTextAlign = "Right",TextSize = 16,IsBold = true,Color = White, Position = { 5, 593 },Size = { 98,37 }})
  return layout, graphics
end


--********************************************************************************
--* Function: GetComponents(props)
--********************************************************************************
function GetComponents(props)
  return 
  { 
    {   
      Name = "nic_storage",
      Type = "scriptable_controls", 
      Properties = 
      {
        ["config"] = '[{"Name":"Core","Count":1.0,"ControlType":"Text","ButtonType":"Momentary","TextType":"TextBox","IndicatorType":"Led","ControlUnit":"dB","Min":-100.0,"Max":12.0,"PinStyle":"None"},{"Name":"Emul","Count":1.0,"ControlType":"Text","ButtonType":"Momentary","TextType":"TextBox","IndicatorType":"Led","ControlUnit":"dB","Min":-100.0,"Max":12.0,"PinStyle":"None"}]'
      }
    }
  }
end


--********************************************************************************
--* Function: Runtime
--********************************************************************************
if Controls then
  --********************************************************************************
  --* Libraries
  --********************************************************************************
  require("json")
  
  --********************************************************************************
  --* Aliases
  --********************************************************************************
  ip = Controls.IPAddress
  nic = Controls.NIC
  localIP = Controls.LocalIP
  rxport = Controls.ReceivePort
  address = Controls.DeviceID
  id = Controls.IDDevice
  phantom = Controls.PhantomPower
  ARM = Controls.ARMC
  psload = Controls.LoadPreset
  pssave = Controls.SavePreset
  status = Controls.Status
  bootver = Controls.BootVersion
  fwver = Controls.FirmwareVersion
  bprev = Controls.ButtonPreview
  
  if Properties["Model"].Value==MODELS[1] then
    CH32 = { --CH32 functions and commands are only relevant to MKI
      LED = {
          Green = { GlobalState, GlobalBright, GlobalInput, State = {}, Bright = {}, Input = {}, Touch = {}, Timer = {} },
          Red = { GlobalState, GlobalBright, GlobalInput, State = {}, Bright = {}, Input = {}, Touch = {}, Timer = {} },
        },
      Button = {}
    }
    CH32.LED.Green.GlobalState = Controls.GlobalGreenState
    CH32.LED.Red.GlobalState = Controls.GlobalRedState
    CH32.LED.Green.GlobalBright = Controls.GlobalGreenBrightness
    CH32.LED.Red.GlobalBright = Controls.GlobalRedBrightness
    CH32.LED.Green.GlobalInput = Controls.GlobalGreenBrightnessInput
    CH32.LED.Red.GlobalInput = Controls.GlobalRedBrightnessInput
    for i=1,4 do
      table.insert(CH32.LED.Green.State,Controls.GreenState[i])
      table.insert(CH32.LED.Red.State,Controls.RedState[i])
      table.insert(CH32.LED.Green.Bright,Controls.GreenBrightness[i])
      table.insert(CH32.LED.Red.Bright,Controls.RedBrightness[i])
      table.insert(CH32.LED.Green.Input,Controls.GreenBrightnessInput[i])
      table.insert(CH32.LED.Red.Input,Controls.RedBrightnessInput[i])
      table.insert(CH32.LED.Green.Touch,true)
      table.insert(CH32.LED.Red.Touch,true)
      table.insert(CH32.LED.Green.Timer,Timer.New())
      table.insert(CH32.LED.Red.Timer,Timer.New())
      table.insert(CH32.Button,Controls.ButtonState[i])
    end
  else -- These commands work for MK2 and for MK3
    TS = {  --TS functions and commands are only relevant to MKII
      LED = {
        Green = { GlobalState, GlobalBright, GlobalInput, State = {}, Bright = {}, Input = {}, Touch = {}, Timer = {} },
        Red = { GlobalState, GlobalBright, GlobalInput, State = {}, Bright = {}, Input = {}, Touch = {}, Timer = {} },
        Blue = { GlobalState, GlobalBright, GlobalInput, State = {}, Bright = {}, Input = {}, Touch = {}, Timer = {} },
      },
      Button = {}
    }
    TS.LED.Green.GlobalState = Controls.GlobalGreenState
    TS.LED.Red.GlobalState = Controls.GlobalRedState
    TS.LED.Blue.GlobalState = Controls.GlobalBlueState
    TS.LED.Green.GlobalBright = Controls.GlobalGreenBrightness
    TS.LED.Red.GlobalBright = Controls.GlobalRedBrightness
    TS.LED.Blue.GlobalBright = Controls.GlobalBlueBrightness
    TS.LED.Green.GlobalInput = Controls.GlobalGreenBrightnessInput
    TS.LED.Red.GlobalInput = Controls.GlobalRedBrightnessInput
    TS.LED.Blue.GlobalInput = Controls.GlobalBlueBrightnessInput
    for i=1,4 do
      table.insert(TS.LED.Green.State,Controls.GreenState[i])
      table.insert(TS.LED.Red.State,Controls.RedState[i])
      table.insert(TS.LED.Blue.State,Controls.BlueState[i])
      table.insert(TS.LED.Green.Bright,Controls.GreenBrightness[i])
      table.insert(TS.LED.Red.Bright,Controls.RedBrightness[i])
      table.insert(TS.LED.Blue.Bright,Controls.BlueBrightness[i])
      table.insert(TS.LED.Green.Input,Controls.GreenBrightnessInput[i])
      table.insert(TS.LED.Red.Input,Controls.RedBrightnessInput[i])
      table.insert(TS.LED.Blue.Input,Controls.BlueBrightnessInput[i])
      table.insert(TS.LED.Green.Touch,true)
      table.insert(TS.LED.Red.Touch,true)
      table.insert(TS.LED.Blue.Touch,true)
      table.insert(TS.LED.Green.Timer,Timer.New())
      table.insert(TS.LED.Red.Timer,Timer.New())
      table.insert(TS.LED.Blue.Timer,Timer.New())
      table.insert(TS.Button,{Controls.ButtonState[i],Controls.ButtonState[((i-1)*2)+5],Controls.ButtonState[((i-1)*2)+6]})
    end
  end
  
  
  --********************************************************************************
  --* Textbox Styles
  --********************************************************************************
  TextBoxStyle = json.encode({StrokeWidth = 2,StrokeColor = "White",CornerRadius = 6})
  address.Style = TextBoxStyle
  ip.Style = TextBoxStyle
  nic.Style = TextBoxStyle
  localIP.Style = TextBoxStyle
  rxport.Style = TextBoxStyle
  status.Style = TextBoxStyle
  
  
  --********************************************************************************
  --* Constants
  --********************************************************************************
  e = System.IsEmulating
  nic_storage = nic_storage[tostring(e and "Emul" or "Core")]
  CDT100 = UdpSocket.New()
  QueueTimer = Timer.New()
  PollTimer = Timer.New()
  HealthTimer = Timer.New()
  ReconnectTimer = Timer.New()
  status_state = { OK = 0, COMPROMISED = 1, FAULT = 2, NOTPRESENT = 3, MISSING = 4, INITIALIZING = 5 }
  PollTime = 1
  HealthTime = 4
  ReconnectTime = 5
  IP_PATTERN = "[012]?%d?%d+%.[012]?%d?%d+%.[012]?%d?%d+%.[012]?%d?%d"
  RXPort = 49494 -- Default UDP Port
  if Properties["Model"].Value==MODELS[1] then
    brightcolor = {R = "Red", G = "Green"}
  else--if Properties["Model"].Value==MODELS[2] then
    brightcolor = {R = "Red", G = "Green", B = "Blue"} -- add a B = "Blue" for MK2
  end
  
  -- Variables and flags
  IsConnected = false
  Queue = {}
  nicTable = {}
  Startup = true
  PollAll = true
  commState = {portOpen = false}
  DebugTx              = false
  DebugRx              = false
  DebugFunction        = false
  DebugPrint           = Properties["Debug Print"].Value
  
  
  --********************************************************************************
  --* Helper Functions
  --********************************************************************************
  
  --********************************************************************************
  --* Function: SetupDebugPrint
  --* Description: A function to determine common print statement scenarios for troubleshooting
  --********************************************************************************
  function SetupDebugPrint()
    if DebugPrint == "Tx/Rx" then
      DebugTx,DebugRx = true,true
    elseif DebugPrint == "Tx" then
      DebugTx = true
    elseif DebugPrint == "Rx" then
      DebugRx = true
    elseif DebugPrint == "Function Calls" then
      DebugFunction = true
    elseif DebugPrint == "All" then
      DebugTx,DebugRx,DebugFunction = true,true,true
    end
  end
  
  --********************************************************************************
  --* Function: Find(a,t)
  --* Description: Finds if a value exists a given array
  --********************************************************************************
  function Find(a,t)
    if DebugFunction then print("Find() Called") end
    local f = false for _,_a in pairs(t) do f=a==_a if f then break end end return f
  end
  
  
  --********************************************************************************
  --* Function: DisplayTable(data)
  --* Description: Prints data from a table
  --********************************************************************************
  function DisplayTable(data)
    if DebugFunction then print("DisplayTable() Called") end
    for k,v in pairs(data) do
      if type(v) == "table" then
        for a,b in pairs(v) do
          print("  --"..k, " ", a, " ", b)
        end
      else
        print("  "..k, " ", v)
      end
    end
  end
  
  
  --********************************************************************************
  --* Function: DebugFormat(string)
  --* Description: Format strings containing non-printable characters so we can see what they are
  --********************************************************************************
  function DebugFormat(string)
    if DebugFunction then print("DebugFormat() Called") end
    local visual = ""
    if type(string) == "string" then
      for i=1,#string do
        local byte = string:sub(i,i)
        if string.byte(byte) >= 32 and string.byte(byte) <= 126 then
          visual = visual..byte
        else
          visual = visual..string.format("(%02xh)",string.byte(byte))
        end
      end
    else
      visual = "Type is: "..type(string)
    end
    return visual
  end
  
  
  --********************************************************************************
  --* Function: RGBToStr(color)
  --* Description: Converts RGB type color to string
  --********************************************************************************
  function RGBToStr(color)
    if DebugFunction then print("RGBToStr() Called") end
    return string.format("#%.2x%.2x%.2x",color[1],color[2],color[3])
  end
  
  
  --********************************************************************************
  --* Function: CheckIPValid(ip)
  --* Description: Check validity of IP address
  --********************************************************************************
  function CheckIPValid(ip)
    if DebugFunction then print("CheckIPValid() Called") end
    local ipValid = true
    if type(ip) == "string" then
      -- check for format 1.11.111.111 for ipv4
      local chunks = {ip:match("^(%d+)%.(%d+)%.(%d+)%.(%d+)$")}
      if #chunks == 4 then
        for _,v in pairs(chunks) do
          if tonumber(v) > 255 then
            ipValid = false
          end
        end
      else
        ipValid = false
      end
    else
      ipValid = false
    end
    return ipValid
  end
  
  
  --********************************************************************************
  --* Function: ReportStatus(state, msg)
  --* Description: Update status message and state to given values
  --********************************************************************************
  function ReportStatus(state, msg)
    if DebugFunction then print("ReportStatus() Called") end
    status.Value = status_state[state]
    status.String = msg
    if (status_state[state] > 0) then
      --print("x"..msg)
    end
  end
  
  
  --********************************************************************************
  --* Function: GetNICIP()
  --* Description: Returns IP table of available network interfaces
  --********************************************************************************
  function GetNICIP()
    if DebugFunction then print("GetNICIP() Called") end
    for k,v in pairs(nicTable) do
      if nic.String == k then
        localIP.String = v
      end
    end
  end
  
  
  --********************************************************************************
  --* Function: UDPSend(ip,uport,data)
  --* Description: TX and Queue Functions
  --********************************************************************************
  function UDPSend(ip,uport,data)
    if DebugFunction then print("UDPSend() Called") end
    if DebugTx then print("Tx: "..data) end
    CDT100:Send(ip,uport,data)
  end
  
  
  --********************************************************************************
  --* Function: SendCommand()
  --* Description: Ensures certain conditions are met before sending data over the socket'
  --* Excluding this command from the DebugTx prints to avoid spam
  --********************************************************************************
  function SendCommand(cmd, ext)
    if DebugFunction then print("SendCommand() Called") end
    if IsConnected or cmd=="SASIP" then
      local senddata = cmd..tostring(ext and " "..ext or "")
      -- Use pcall to test whether ip is reachable to avoid crashing
      local ipgood, result = pcall(UDPSend,ip.String,49494,senddata.."\r" )
      if not ipgood then
        print("IP not reachable; Command: "..result)
      end
    end
  end
  
  
  --********************************************************************************
  --* Function: QueueProcess()
  --* Description: Deal with queued messages
  --********************************************************************************
  function QueueProcess()
    if DebugFunction then print("QueueProcess() Called") end
    QueueTimer:Stop()
    if #Queue>0 then
      QueueRun = true
      local qitem = table.remove(Queue,1)
      SendCommand(qitem[1],qitem[2])
    else
      QueueRun = false
      PollTimer:Start(PollTime)
    end
  end
  
  
  --********************************************************************************
  --* Function: ToQueue(cmd,ext)
  --* Description: Add message to the queue
  --********************************************************************************
  function ToQueue(cmd,ext)
    if DebugFunction then print("ToQueue() Called") end
    if (commState.portOpen) then
      table.insert(Queue,{cmd,ext})
      if not QueueRun and IsConnected then
        QueueProcess()
      end
    end
  end
  
  
  --********************************************************************************
  --* Function: ParseResponses(pdata)
  --* Description: Parse messages rtuerned from device
  --********************************************************************************
  function ParseResponses(pdata)
    if DebugFunction then print("ParseResponse() Called") end
    if pdata ~= nil then
      if DebugRx then print("Rx: "..pdata) end
    end
    --********************************************************************************
    --* Function: UpdateGlobalState(btnColor)
    --* Descriotion: Udpates spcific color of global state based on individual channel settings
    --********************************************************************************
    function UpdateGlobalState(btnColor)
      if DebugFunction then print("UpdateGlobalState() Called") end
      --print("UpdateGoblalState",btnColor)
      local onCount = 0
      local offCount = 0
      for i = 1, 4 do
        if Controls[btnColor.."State"][i].Boolean then
          onCount = onCount + 1
        elseif not Controls[btnColor.."State"][i].Boolean then
          offCount = offCount + 1
        end
      end
      if onCount == 4 and offCount == 0 then
        Controls["Global"..btnColor.."State"].Value = true
      elseif onCount < 4 and offCount > 0 then
        Controls["Global"..btnColor.."State"].Value = false
      end
    end
  
    --********************************************************************************
    if IsConnected then
      QueueProcess()
      HealthTimer:Start(HealthTime)
    end
    local ack, cmd, param = string.match(pdata,"([N]?ACK) (%w+)[ ]*(.*)")
    if ack==nil then
      local args = {}
      for arg in string.gmatch(pdata,"[^ ]+") do
        table.insert(args,arg)
      end
      if args[1] == "BSTATUS" then
        local bId,bool = string.match(args[2],"B(%d+)=(%d)")
        Controls.ButtonState[tonumber(bId)].Boolean = bool=="1"
      else
        print("Other: "..pdata)
      end
    else
      --print("RX: "..DebugFormat(pdata))
    end
    if ack == "ACK" then
      if cmd=="SASIP" then
        if param:find("0.0.0.0") then
          CDT100:Close()
          HealthTimer:Stop()
          ReportStatus("MISSING", "")
        else
          IsConnected = true
          ReconnectTimer:Stop()
          QueueProcess()
          ReportStatus("OK", "")
          --print("Connected.")
          status.Value = 0
          HealthTimer:Start(HealthTime)
        end
      elseif cmd=="GAS" then
        address.String = param
      elseif cmd=="QUERY" then
        local PP1, PP2, PP3, PP4, ID = string.match(param,"PP1=(%a+) PP2=(%a+) PP3=(%a+) PP4=(%a+) ID=(%a+)")
        local PPTable = { PP1=="ON", PP2=="ON", PP3=="ON", PP4=="ON" }
        id.Boolean = ID=="ON"
        for key,val in ipairs(PPTable) do
          phantom[key].Boolean = val
          phantom[key].Legend = val and "ON" or "OFF"
        end
      elseif cmd=="GCH32" then
        for arg in string.gmatch(param,"[^ ]+") do
          if arg~="0" then
            local bId,btype,bool = arg:match("CH(%d)(%a+)=(%d)")
            bool, bId = bool=="1", tonumber(bId)
            local btypes = {R = "LED", G = "LED",   SC = "Button"      }
            local bcolor = {R = "Red", G = "Green", SC = tonumber(bId) }
            if btypes[btype]=="Button" then
              CH32[btypes[btype]][bcolor[btype]].Boolean = bool
            elseif btypes[btype]=="LED" then
              CH32[btypes[btype]][bcolor[btype]].State[bId].Boolean = bool
            end
          end
        end
        UpdateGlobalState("Green")
        UpdateGlobalState("Red")
        for i=1,4 do
          ButtonPreview(i)
        end
      elseif cmd=="GTS" then
        for arg in string.gmatch(param,"[^ ]+") do
          if arg~="0" then
            local bId,btype,sw,bool = arg:match("CH(%d)(%a+)(%d?)=(%d)")
            bool, bId = bool=="1", tonumber(bId)
            local btypes = {R = "LED", G = "LED", B = "LED", SC = "Button" }
            local bcolor = {R = "Red", G = "Green", B = "Blue", SC = tonumber(bId) }
            if btypes[btype]=="Button" then
              TS[btypes[btype]][bcolor[btype]][tonumber(sw)].Boolean = bool
            elseif btypes[btype]=="LED" then
              TS[btypes[btype]][bcolor[btype]].State[bId].Boolean = bool
            end
          end
        end
        UpdateGlobalState("Green")
        UpdateGlobalState("Red")
        UpdateGlobalState("Blue")
        for i=1,4 do
          ButtonPreview(i)
        end
      elseif cmd=="GCH32B" then
        local ch = tonumber(param:sub(1,1))
        if ch==0 then
          for bru in string.gmatch(param:sub(3),"%w+=%d+") do
            local ch,clr,lev = bru:match("CH(%d)(%a)=(%d+)")
            CH32.LED[brightcolor[clr]].Bright[tonumber(ch)].Position = lev/100
            if clr == "R" then CH32.LED.Red.Input[tonumber(ch)].Value = CH32.LED[brightcolor[clr]].Bright[tonumber(ch)].Value end
            if clr == "G" then CH32.LED.Green.Input[tonumber(ch)].Value = CH32.LED[brightcolor[clr]].Bright[tonumber(ch)].Value end
          end
        else
          local clr,lev = param:match(ch.." (%a)=(%d+)")
          if CH32.LED[brightcolor[clr]].Touch[ch] then CH32.LED[brightcolor[clr]].Bright[ch].Position = lev/100 end
        end
      elseif cmd:find("SCH32B") then
        --Do nothing as this is just the ACK from the send
      elseif cmd == "GRGB" then
        local ch = tonumber(param:sub(1,1))
        if ch==0 then
          for arg in string.gmatch(param,"CH%d %d+ %d+ %d+") do
            local ch,rVal,gVal,bVal = arg:match("CH(%d) (%d+) (%d+) (%d+)")
            TS.LED.Red.Bright[tonumber(ch)].Value = rVal
            TS.LED.Red.Input[tonumber(ch)].Value = rVal
            TS.LED.Green.Bright[tonumber(ch)].Value = gVal
            TS.LED.Green.Input[tonumber(ch)].Value = gVal
            TS.LED.Blue.Bright[tonumber(ch)].Value = bVal
            TS.LED.Blue.Input[tonumber(ch)].Value = bVal
          end
        end
      elseif cmd == "SRGB" then
        --Do nothing as this is just the ACK from the send
        --  If this message is in response to the user moving the fader, values
        --  it contains may be behind the current fader value and using those
        --  values to update the UI will cause the fader to jump back towards
        --  its previous value making the UI behave oddly
      elseif cmd=="GARMC" or cmd=="SARMC" then
        ARM.Boolean = param=="1"
        ARM.Legend = param=="1" and "ON" or "OFF"
      elseif cmd=="ID" then
        id.Boolean = param=="1"
      elseif cmd=="PP" then
        local ch,st = param:match("(%d) (%d)")
        phantom[tonumber(ch)].Boolean = st=="1"
        phantom[tonumber(ch)].Legend = st=="1" and "ON" or "OFF"
      elseif cmd=="VERSION" then
        fwver.String = "v"..param
      elseif cmd=="BVERSION" then
        bootver.String = "v"..param
      elseif cmd=="SCH32" then
        local ch,btype,b = param:match("(%d) (%a)=(%d)")
        if ch == "0" then
          for loop = 1,4 do
            CH32.LED[brightcolor[btype]].State[loop].Boolean = b=="1"
            ButtonPreview(loop)
          end
        else
          CH32.LED[brightcolor[btype]].State[tonumber(ch)].Boolean = b=="1"
        end
        UpdateGlobalState(brightcolor[btype])
      elseif cmd=="STS" then
        local ch,btype,b = param:match("(%d) (%a)=(%d)")
        if ch == "0" then
          for loop = 1,4 do
            TS.LED[brightcolor[btype]].State[loop].Boolean = b=="1"
            ButtonPreview(loop)
          end
        else
          TS.LED[brightcolor[btype]].State[tonumber(ch)].Boolean = b=="1"
        end
        UpdateGlobalState(brightcolor[btype])
      elseif cmd=="SAVE" then
        --print("saved preset")
      elseif cmd=="LOAD" then
        PollAll = true
        PollCommands()
      elseif cmd=="SMKMD" then
        --do nothing as its a set
      else
        print("Unknown",cmd,param,"--> "..pdata)
      end
    elseif ack == "NACK" then
      -- We might want to add a FAULT status message for malformed cmds
      -- TBD when we get more granular with Reflect reporting
    end
  end
  
  
  --********************************************************************************
  --* Function: CDT100.EventHandler
  --* Description: Checks responses from UDP messages
  --* Excluding this from DebugFunction print statements to avoid spam
  --********************************************************************************
  CDT100.EventHandler = function(udp, packet)
    -- eliminate stray newlines
    local pdata = string.match(string.gsub(packet.Data,"\n",""),"([^\r]+)")
    -- Filters out response packets from other CDT100's
    if packet.Address == ip.String then
      ParseResponses(pdata)
    end
  end
  
  
  --********************************************************************************
  --* Function: PollCommands()
  --* Description: Initiate sending of commands taht need to be polled
  --********************************************************************************
  function PollCommands()
    if DebugFunction then print("PollCommands() Called") end
    PollTimer:Stop()
    if PollAll then
      if Properties[PROP_MODEL].Value==MODELS[1] then
        ToQueue("SMKMD","1") -- Added to set MK model upon startup
        ToQueue("GCH32","0") -- Get CH32 Status
        ToQueue("GCH32B","0") -- Get CH32 LED Brightness Status
      else--if Properties[PROP_MODEL].Value==MODELS[2] then
        ToQueue("SMKMD","2") -- Added to set MK model upon startup
        ToQueue("GTS","0") -- Get TS Status
        --ToQueue("GTSB","0") -- Get TS LED Brightness Status
        ToQueue("GRGB","0") -- Get TS LED RGB levels
      end
      ToQueue("GARMC") -- Get ARM-C State
      ToQueue("QUERY") -- Retrieve Current Settings
    end
    ToQueue("GAS") -- Get Address Switch
    PollAll = false
  end
  
  
  --********************************************************************************
  --* Function: InitCommands()
  --* Description: Send intiial commands to determine device state
  --********************************************************************************
  function InitCommands()
    if DebugFunction then print("InitCommands() Called") end
    SendCommand("SASIP",localIP.String..":"..RXPort) -- Turn on async msgs
    ToQueue("VERSION")
    ToQueue("BVERSION")
    PollCommands()
  end
  
  
  --********************************************************************************
  --* Function: DisconnectFromDevice()
  --* Description: Terminates the device connection
  --********************************************************************************
  function DisconnectFromDevice()
    if DebugFunction then print("DisconnectFromDevice() Called") end
    HealthTimer:Stop()
    ReconnectTimer:Stop()
    PollTimer:Stop()
    CDT100:Close()
    commState.portOpen = false
    IsConnected = false
    Queue = {}
  end
  
  
  --********************************************************************************
  --* Function: GetNICTable()
  --* Description: Returns table of available network interfaces
  --********************************************************************************
  function GetNICTable()
    if DebugFunction then print("GetNICTable() Called") end
    nicTable = {}
    local nics = Qlib.networkinterfaces()
    for _,n in ipairs(nics) do
      if not string.find(n.Interface, "Loopback") then
        nicTable[n.Interface] = n.Address
      end
    end
  end
  
  
  --********************************************************************************
  --* Function: SourceNIC()
  --* Description: Gets available network interfaces and confirms local IP address
  --********************************************************************************
  function SourceNIC()
    if DebugFunction then print("SourceNIC() Called") end
    GetNICTable()
    local list = {}
    for k,v in pairs(nicTable) do
      table.insert(list, k)
    end
  
    --Confirm what the local NIC should be based on current run mode...
    nic.Choices = list
    if #list > 0 then
      if Find(nic.String, list) then  --if local NIC in list...
        --Good to go
        if nic.String ~= nic_storage.String then
          nic_storage.String = nic.String  --Store local NIC if stored NIC not the same
        end
        nic.Color = RGBToStr(Color.White)
        GetNICIP()
      else
        if Find(nic_storage.String, list) then  --if stored NIC in list...
          --Good to go
          nic.String = nic_storage.String
          nic.Color = RGBToStr(Color.White)
          GetNICIP()
        else
          --Can't find either local or stored NIC
          nic.Color = RGBToStr(Color.Red)
          localIP.String = ""
          ReportStatus("MISSING", (nic.String == "") and "NIC not selected" or "NIC not found")
        end
      end
    else
      nic.Color = RGBToStr(Color.Red)
      ReportStatus("MISSING", "No NIC found")
    end
  end
  
  
  --********************************************************************************
  --* Function: NicComboBoxEvent
  --* Description: Event Handler for NIC ComboBox change
  --********************************************************************************
  function NicComboBoxEvent()
    if DebugFunction then print("NicComboBoxEvent() Called") end
    if nic.String ~= "" then
      nic.Color = RGBToStr(Color.White)
      nic_storage.String = nic.String
      GetNICIP()
      --print("Network:", nic.String, localIP.String)
    end
    if commState.portOpen then
      DisconnectFromDevice()
    end
    Connect()
  end
  
  
  --********************************************************************************
  --* Function: IPAddrEvent()
  --* Description: Event Handler for IP address ComboBox change
  --********************************************************************************
  function IPAddrEvent()
    if DebugFunction then print("IPAddrEvent() Called") end
    if commState.portOpen then
      DisconnectFromDevice()
    end
    Connect()
  end
  
  
  --********************************************************************************
  --* Function: RecPortEvent()
  --* Description: Event Handler for IP address ComboBox change
  --********************************************************************************
  function RecPortEvent()
    if DebugFunction then print("RecPortEvent() Called") end
    if commState.portOpen then
      DisconnectFromDevice()
    end
    Connect()
  end
  
  
  --********************************************************************************
  --* Function: ConnectedLegend(ctl)
  --* Description: Updates phantom power button legend depending on current state
  --********************************************************************************
  function ConnectedLegend(ctl)
    if DebugFunction then print("ConnectedLegend() Called") end
    if not IsConnected then
      ctl.Legend = ctl.Boolean and "ON" or "OFF"
    end
  end
  
  
  --********************************************************************************
  --* Function: BrightRender(clr,lev,ch)
  --* Description: Renders the color of the brightness fader based on current values
  --* Note - "lev"should be fader "position" to make it easier to calculate the new color
  --********************************************************************************
  function BrightRender(clr,lev,ch)
    if DebugFunction then print("BrightRender() Called") end
    --print("BrightRender",clr,lev,ch)
    if clr == "r" then clr = "Red" end
    if clr == "g" then clr = "Green" end
    if clr == "b" then clr = "Blue" end
  
    local color = {Red=0,Green=0,Blue=0}
    color[clr] = math.modf(255*lev)
    if ch==0 then --Global
      Controls["Global"..clr.."Brightness"].Color = string.format("#%02x%02x%02x",color.Red,color.Green,color.Blue)
    else
      Controls[clr.."Brightness"][ch].Color = string.format("#%02x%02x%02x",color.Red,color.Green,color.Blue)
    end
  end
  
  
  --********************************************************************************
  --* Function: ButtonPreview(ch)
  --* Description: Updates Led buttons and button preview based on current setting
  --********************************************************************************
  function ButtonPreview(ch)
    if DebugFunction then print("ButtonPreview() Called") end
    if Properties[PROP_MODEL].Value==MODELS[1] then
      local color = {r=0,g=0,b=0}
      for k,v in pairs(color) do
        if CH32.LED[brightcolor["R"]].State[ch].Boolean then color.r = math.floor((CH32.LED[brightcolor["R"]].Bright[ch].Value/10)*0xFF) else color.r = 0 end
        if CH32.LED[brightcolor["G"]].State[ch].Boolean then color.g = math.floor((CH32.LED[brightcolor["G"]].Bright[ch].Value/10)*0xFF) else color.g = 0 end
        color.b = 0
      end
      Controls["ButtonPreview"][ch].Color = string.format("#%02x%02x%02x",color.r,color.g,color.b)
    else--if Properties[PROP_MODEL].Value==MODELS[2] then
      local color = {r=0,g=0,b=0}
      for k,v in pairs(color) do
        if TS.LED[brightcolor["R"]].State[ch].Boolean then color.r = TS.LED[brightcolor["R"]].Bright[ch].Value else color.r = 0 end
        if TS.LED[brightcolor["G"]].State[ch].Boolean then color.g = TS.LED[brightcolor["G"]].Bright[ch].Value else color.g = 0 end
        if TS.LED[brightcolor["B"]].State[ch].Boolean then color.b = TS.LED[brightcolor["B"]].Bright[ch].Value else color.b = 0 end
      end
      Controls["ButtonPreview"][ch].Color = string.format("#%02x%02x%02x",color.r,color.g,color.b)
    end
  end
  
  
  --********************************************************************************
  --* Function: Initialization()
  --* Description:
  --********************************************************************************
  function Initialization()
    if DebugFunction then print("Initialization() Called") end
    SourceNIC()
    nic.EventHandler = NicComboBoxEvent
    localIP.EventHandler = IPAddrEvent
    rxport.EventHandler = RecPortEvent
    id.Boolean = false
    id.EventHandler = function()
      if IsConnected then
        ToQueue("ID",id.Boolean and 1 or 0)
      end
    end
    ARM.EventHandler = function(ctl)
      if IsConnected then
        ToQueue("SARMC",math.floor(ctl.Value))
      end
    end
    psload.EventHandler = function()
      if IsConnected then
        ToQueue("LOAD",0)
      end
    end
    pssave.EventHandler = function(ctl)
      if IsConnected then
        if ctl.Boolean then
          ToQueue("SAVE",0)
        end
      end
    end
    if Properties[PROP_MODEL].Value==MODELS[1] then
      for i=1,4 do
        phantom[i].EventHandler = function(ctl)
          if not Startup and IsConnected then
            ToQueue("PP",string.format("%i %i",i,ctl.Value))
          end
        end
        for _,clr in ipairs{"g","r"} do
          local UClr = clr:upper()
          local cname = brightcolor[UClr]
          CH32.LED[cname].State[i].EventHandler = function(ctl)
            if not Startup and IsConnected then
              ToQueue("SCH32",string.format("%i %s=%i",i,UClr,ctl.Value))
              ButtonPreview(i)
            end
          end
          CH32.LED[cname].Bright[i].EventHandler = function(ctl)
            if ctl.Value < 1 then
              CH32.LED[cname].State[i].Boolean = false
              ToQueue("SCH32",string.format("%i %s=%i",i,UClr,0))
            else
              CH32.LED[cname].State[i].Boolean = true
              ToQueue("SCH32",string.format("%i %s=%i",i,UClr,1))
            end
            CH32.LED[cname].Bright[i].Value = ctl.Value
            CH32.LED[cname].Input[i].Value = ctl.Value
            if not Startup and IsConnected then
              CH32.LED[cname].Timer[i]:Start(.25)
              CH32.LED[cname].Touch[i]=false
              ToQueue("SCH32B",string.format("%i %s=%i0",i,UClr,ctl.Value)) --10% increments
              BrightRender(clr,ctl.Position,i)
              ButtonPreview(i)
            end
          end
          CH32.LED[cname].Input[i].EventHandler = CH32.LED[cname].Bright[i].EventHandler
          CH32.LED[cname].Timer[i].EventHandler = function(tmr)
            tmr:Stop()
            CH32.LED[cname].Touch[i]=true
          end
        end
      end
  
      --Global stuff
      for k,v in pairs(brightcolor) do
        CH32.LED[v].GlobalState.EventHandler = function(ctl)
          if not Startup and IsConnected then
            for loop=1,4 do
              CH32.LED[v].State[loop].Boolean = ctl.Boolean
              ButtonPreview(loop)
            end
            ToQueue("SCH32",string.format("0 %s=%i",k,ctl.Value))
          end
        end
  
        CH32.LED[v].GlobalBright.EventHandler = function(ctl)
          if ctl.Value < 1 then
            CH32.LED[v].GlobalState.Boolean = false
            ToQueue("SCH32",string.format("0 %s=%i",k,0))
          else
            CH32.LED[v].GlobalState.Boolean = true
            ToQueue("SCH32",string.format("0 %s=%i",k,1))
          end
          CH32.LED[v].GlobalInput.Value = ctl.Value    --Need both these as same code runs from input fader and text box
          CH32.LED[v].GlobalBright.Value = ctl.Value   --Need both these as same code runs from input fader and text box
          BrightRender(string.lower(k),ctl.Position,0) -- Render global color
          for i = 1,4 do
            CH32.LED[v].State[i].Boolean = (ctl.Value < 1) and false or true
            CH32.LED[v].Input[i].Value = ctl.Value
            CH32.LED[v].Bright[i].Value = ctl.Value
            if not Startup and IsConnected then
              CH32.LED[v].Timer[i]:Start(.25)
              CH32.LED[v].Touch[i]=false
              BrightRender(string.lower(k),ctl.Position,i) --Render individual colors
            end
          end
          ToQueue("SCH32B",string.format("0 %s=%i0",k,ctl.Value)) --10% increments
        end
        CH32.LED[v].GlobalInput.EventHandler = CH32.LED[v].GlobalBright.EventHandler
      end
    else--if Properties[PROP_MODEL].Value==MODELS[2] then
      for i=1,4 do
        phantom[i].EventHandler = function(ctl)
          if not Startup and IsConnected then
            ToQueue("PP",string.format("%i %i",i,ctl.Value))
            ConnectedLegend(ctl)
          end
        end
        for _,clr in ipairs{"g","r","b"} do
          local UClr = clr:upper()
          local cname = brightcolor[UClr]
          TS.LED[cname].State[i].EventHandler = function(ctl)
            if not Startup and IsConnected then
              ToQueue("STS",string.format("%i %s=%i",i,UClr,ctl.Value))
              ButtonPreview(i)
            end
          end
          TS.LED[cname].Bright[i].EventHandler = function(ctl)
            if ctl.Value < 1 then
              TS.LED[cname].State[i].Boolean = false
              ToQueue("STS",string.format("%i %s=%i",i,UClr,0))
            else
              TS.LED[cname].State[i].Boolean = true
              ToQueue("STS",string.format("%i %s=%i",i,UClr,1))
            end
            TS.LED[cname].Input[i].Value = ctl.Value --Need both these as same code runs from input fader and text box
            TS.LED[cname].Bright[i].Value = ctl.Value --Need both these as same code runs from input fader and text box
            if not Startup and IsConnected then
              TS.LED[cname].Timer[i]:Start(.25)
              TS.LED[cname].Touch[i]=false
              ToQueue("SRGB",string.format("%i %i %i %i",i,TS.LED.Red.Bright[i].Value,TS.LED.Green.Bright[i].Value,TS.LED.Blue.Bright[i].Value))
              BrightRender(clr,ctl.Position,i)
              ButtonPreview(i)
            end
          end
          TS.LED[cname].Input[i].EventHandler = TS.LED[cname].Bright[i].EventHandler
          TS.LED[cname].Timer[i].EventHandler = function(tmr)
            tmr:Stop()
            TS.LED[cname].Touch[i]=true
          end
        end
      end
  
      --Global stuff
      for k,v in pairs(brightcolor) do
        TS.LED[v].GlobalState.EventHandler = function(ctl)
          if not Startup and IsConnected then
            for loop=1,4 do
              TS.LED[v].State[loop].Boolean = ctl.Boolean
              ButtonPreview(loop)
            end
            ToQueue("STS",string.format("0 %s=%i",k,ctl.Value))
          end
        end
  
        TS.LED[v].GlobalBright.EventHandler = function(ctl)
          if ctl.Value < 1 then
            TS.LED[v].GlobalState.Boolean = false
            ToQueue("STS",string.format("0 %s=%i",k,0))
          else
            TS.LED[v].GlobalState.Boolean = true
            ToQueue("STS",string.format("0 %s=%i",k,1))
          end
          TS.LED[v].GlobalInput.Value = ctl.Value  --Need both these as sam code runs from input fader and text box
          TS.LED[v].GlobalBright.Value = ctl.Value --Need both these as sam code runs from input fader and text box
          BrightRender(string.lower(k),ctl.Position,0) -- Render global color
          for i = 1,4 do
            TS.LED[v].State[i].Boolean = (ctl.Value < 1) and false or true
            TS.LED[v].Input[i].Value = ctl.Value
            TS.LED[v].Bright[i].Value = ctl.Value
            if not Startup and IsConnected then
              TS.LED[v].Timer[i]:Start(.25)
              TS.LED[v].Touch[i]=false
              BrightRender(string.lower(k),ctl.Position,i) --Render individual colors
            end
          end
          ToQueue("SRGB",string.format("0 %i %i %i",TS.LED.Red.GlobalBright.Value,TS.LED.Green.GlobalBright.Value,TS.LED.Blue.GlobalBright.Value))
        end
        TS.LED[v].GlobalInput.EventHandler = TS.LED[v].GlobalBright.EventHandler
      end
    end
    Startup = false
  end
  
  
  --********************************************************************************
  --* Function: Connect()
  --* Description:
  --********************************************************************************
  function Connect()
    if DebugFunction then print("Connect() Called") end
    --********************************************************************************
    --* Function: OpenPorts(portIP)
    --* Description: Calls open for fucntion for all UDP connections
    --********************************************************************************
    function OpenPorts(portIP)
      CDT100:Open(portIP, RXPort)
    end
  
    --********************************************************************************
    if not CheckIPValid(localIP.String) or nic.Color == RGBToStr(Color.Red) then
      ReconnectTimer:Start(ReconnectTime)
    elseif not CheckIPValid(ip.String) then
      ReportStatus("MISSING", "Invalid IP")
      ReconnectTimer:Start(ReconnectTime)
    else
      if not IsConnected then
        PollAll = true
        RXPort = math.floor(rxport.Value)
        if not commState.portOpen then
          local portGood,err = pcall(OpenPorts, localIP.String)
          if not portGood then
            --print(err.." - OpenPorts: "..localIP.String)
            ReportStatus("MISSING", err)
          else
            commState.portOpen = true
          end
        end
        if commState.portOpen then
          InitCommands()
          HealthTimer:Start(HealthTime)
        else
          ReconnectTimer:Start(ReconnectTime)
        end
      end
    end
  end
  
  
  --********************************************************************************
  --* Function: InitBright()
  --* Description: Initializes brightness controls
  --********************************************************************************
  function InitBright()
    if DebugFunction then print("InitBright() Called") end
    for _,k in ipairs{"Green","Red"} do
      for _,ctl in pairs(Controls[k.."Brightness"]) do
        ctl.Boolean = true
      end
      Controls["Global"..k.."Brightness"].Boolean = true
      for _,ctl in pairs(Controls[k.."BrightnessInput"]) do
        ctl.Value = (Properties[PROP_MODEL].Value==MODELS[1]) and 10 or 255
      end
      Controls["Global"..k.."BrightnessInput"].Value = (Properties[PROP_MODEL].Value==MODELS[1]) and 10 or 255
    end
    if Properties[PROP_MODEL].Value~=MODELS[1] then
      for _,ctl in pairs(Controls["BlueBrightness"]) do
        ctl.Boolean = true
      end
      for _,ctl in pairs(Controls["BlueBrightnessInput"]) do
        ctl.Value = 255
      end
      Controls["GlobalBlueBrightness"].Boolean = true
      Controls["GlobalBlueBrightnessInput"].Value = 255
    end
  end
  
  
  --********************************************************************************
  --* Function: ConnectHealth()
  --* Description: Event handler function for HealthTimer
  --********************************************************************************
  function ConnectHealth()
    if DebugFunction then print("ConnectHealth() Called") end
    ReportStatus("MISSING", "")
    DisconnectFromDevice()
    HealthTimer:Stop()
    ReconnectTimer:Start(ReconnectTime)
    IsConnected = false
    QueueRun = false
    QueueTimer:Stop()
    Queue = {}
  end
  
  
  --********************************************************************************
  --* Function: ReconnectHandler()
  --* Description: Event handler function for ReconnectTimer
  --********************************************************************************
  function ReconnectHandler()
    if DebugFunction then print("ReconnectHandler() Called") end
    SourceNIC()
    Connect()
  end
  
  
  --********************************************************************************
  --* Function: Init()
  --* Description: Basic Initialisation
  --********************************************************************************
  function Init()
    SetupDebugPrint()
    if DebugFunction then print("Init() Called") end
    if ip.String=="" and fwver.String=="" then
      rxport.Value=RXPort
      InitBright()
    end
    ip.EventHandler = Connect
    PollTimer.EventHandler = PollCommands
    HealthTimer.EventHandler = ConnectHealth
    ReconnectTimer.EventHandler = ReconnectHandler
    QueueTimer.EventHandler = QueueProcess
    Initialization()
    Connect()
  end
  
  
  --********************************************************************************
  --* Global code
  --********************************************************************************
  Init()
end