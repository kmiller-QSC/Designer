      layout["RedState "..i] = {PrettyName = string.format("Channel %i~LED~Red~State",i),Style = "Button",ButtonStyle = "Toggle",Color = LEDRed,Position = { 50+i*123, 434 },Size = { 45, 45 },Radius = 2,Margin = 2}
      layout["RedBrightness "..i] = {PrettyName = string.format("Channel %i~LED~Red~Brightness Fader",i),Style = "Fader",Position = { i*123+50, 491 },Size = { 45, 18 },Color = { 255, 0, 0 }}
      layout["RedBrightnessInput "..i] = {PrettyName = string.format("Channel %i~LED~Red~Brightness Input",i),Style = "Text",TextBoxStyle = "Normal",Color = LtBlue,Position = { 171+(i-1)*123, 514 },Size = { 45, 17 },TextFontSize = 10}
      layout["ButtonState "..i] = {PrettyName = string.format("Channel %i~Switch State",i),IsReadOnly = true,Style = "Button",Color = LEDAmb,Position = { 30+i*124, 556 },Size = { 26, 17 },Radius = 2}
      layout["ButtonPreview "..i] = {PrettyName = string.format("Channel %i~Button Preview",i),Style = "Led",Color = BtnGray,UnlinkOffColor = true,OffColor = BtnGray,CornerRadius = 20,Margin = 3,Padding = 5,Position = { 148+(i-1)*124, 594 },Size = { 37, 35 }}
    end
