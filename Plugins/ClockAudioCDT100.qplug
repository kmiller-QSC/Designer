    -- Separator between channel labels and LED color
    table.insert(graphics,{Type = "GroupBox",Fill = White,StrokeWidth = 0,Position = { 105, 425 },Size = { 493, 1 }})
    -- Separator between LED color and channel brightness
    table.insert(graphics,{Type = "GroupBox",Fill = White,StrokeWidth = 0,Position = { 105, 485 },Size = { 493, 1 }})
    -- Separator between channel brightness and switch state
    table.insert(graphics,{Type = "GroupBox",Fill = White,StrokeWidth = 0,Position = { 105, 544 },Size = { 493, 1 }})
    -- Separator between switch state and button preview
    table.insert(graphics,{Type = "GroupBox",Fill = White,StrokeWidth = 0,Position = { 105, 585 },Size= { 494, 1 }})
  
    table.insert(graphics,{Type = "Text",Text = "CH32",TextSize = 25,IsBold = true,Color = White,Position = { 314, 258 },Size = { 71, 25 }})
    -- Preset groupbox
    table.insert(graphics,{Type = "GroupBox",Fill = GroupFill,StrokeColor = White,StrokeWidth = 1,CornerRadius = 5,Position = { 154, 651 },Size = { 321, 64 }})
    table.insert(graphics,{Type = "Text",Text = "Preset",IsBold = true,TextSize = 18,Color = White,Position = { 154, 651 },Size = { 321, 23 }})
    table.insert(graphics,{Type = "Text",Text = "(applies to Phantom Power and ARM-C only)",TextSize = 7,Color = White,Position = { 154, 704 },Size = { 321, 11 }})
