    layout["LoadPreset"] = {PrettyName = "Preset~Load",Legend = "Preset Load",IsBold = true,Style = "Button",ButtonStyle = "Trigger",Color = BtnLtBlue,OffColor = BtnDkBlue,UnlinkOffColor = true,Position = { 335, 675 },Size = { 124, 32 },Radius = 2,Margin = 2,TextFontSize = 16}
    layout["SavePreset"] = {PrettyName = "Preset~Save",Legend = "Preset Save",IsBold = true,Style = "Button",ButtonStyle = "Momentary",Color = BtnLtBlue,OffColor = BtnDkBlue,UnlinkOffColor = true,Position = { 517, 675 },Size = { 124, 32 },Radius = 2,Margin = 2,TextFontSize = 16}
    layout["BootVersion"] = {PrettyName = "Version~Boot",Style = "Textbox",IsReadOnly = true,TextBoxStyle = "NoBackground",HTextAlign = "Right",VTextAlign = "Center",Color = White,Position = { 181, 673 },Size = { 43, 20 },TextFontSize = 16,IsBold = true, TextColor = White}
    layout["FirmwareVersion"] = {PrettyName = "Version~Firmware",Style = "Textbox",IsReadOnly = true,TextBoxStyle = "NoBackground",HTextAlign = "Right",VTextAlign = "Center",Color = White,Position = { 181, 693 },Size = { 43, 20 },TextFontSize = 16,IsBold = true, TextColor = White}
    -- Channel controls
    layout["GlobalGreenState"] = {PrettyName = "Global LED~Green~State",Style = "Button",ButtonStyle = "Toggle",Color = LEDGrn,Position = { 378, 289 },Size = { 45, 45 },Radius = 2,Margin = 2}
