    table.insert(graphics,{Type = "Text",Text = "Status",TextSize = 14,HTextAlign = "Right",IsBold = true,Color = White,Position = { 194, 118 },Size = { 48, 32 }})
    -- Phantom Power groupbox
    table.insert(graphics,{Type = "GroupBox",Fill = GroupFill,StrokeColor = White,StrokeWidth = 1,CornerRadius = 5,Position = { 105, 201 },Size = { 394, 49 }})
    table.insert(graphics,{Type = "Text",Text = "Phantom Power",TextSize = 23,IsBold = true,Color = White,Position = { 206, 156 },Size = { 194, 24 }})
    -- ARM-C groupbox
    table.insert(graphics,{Type = "GroupBox",Fill = GroupFill,StrokeColor = White,StrokeWidth = 1,CornerRadius = 5,Position = { 501, 201 },Size = { 99, 49 }})
    table.insert(graphics,{Type = "Text",Text = "ARM-C",TextSize = 23,IsBold = true,Color = White,Position = { 502, 156 },Size = { 97, 24 }})
    table.insert(graphics,{Type = "Text",Text = "Microphone",TextSize = 18,Color = White,Position = { 502, 176 },Size = { 97, 24 }})
    -- CH32 groupbox
    table.insert(graphics,{Type = "GroupBox",Fill = GroupFill,StrokeColor = White,StrokeWidth = 1,CornerRadius = 5,Position = { 105, 280 },Size = { 493, 358 }})
    -- Separator between Global LED color and global brightness
    table.insert(graphics,{Type = "GroupBox",Fill = White,StrokeWidth = 0,Position = { 105, 340 },Size = { 493, 1 }})
