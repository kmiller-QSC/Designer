    end
  
  elseif CDType == MODELS[2] then
    -- Controls graphics
    layout["IPAddress"] = {PrettyName = "IP Address",Style = "Text",Color = LtBlue,Position = { 185, 36 },Size = { 230, 32 },TextFontSize = 18}
