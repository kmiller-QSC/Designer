    layout["LoadPreset"] = {PrettyName = "Preset~Load",Legend = "Preset Load",IsBold = true,Style = "Button",ButtonStyle = "Trigger",Color = BtnLtBlue,OffColor = BtnDkBlue,UnlinkOffColor = true,Position = { 170, 675 },Size = { 124, 32 },Radius = 2,Margin = 2,TextFontSize = 16}
    layout["SavePreset"] = {PrettyName = "Preset~Save",Legend = "Preset Save",IsBold = true,Style = "Button",ButtonStyle = "Momentary",Color = BtnLtBlue,OffColor = BtnDkBlue,UnlinkOffColor = true,Position = { 335, 675 },Size = { 124, 32 },Radius = 2,Margin = 2,TextFontSize = 16}
    layout["BootVersion"] = {PrettyName = "Version~Boot",Style = "Textbox",IsReadOnly = true,TextBoxStyle = "NoBackground",HTextAlign = "Right",VTextAlign = "Center",TextColor = White,Position = { 91, 673 },Size = { 43, 20 },TextFontSize = 16,IsBold = true}
    layout["FirmwareVersion"] = {PrettyName = "Version~Firmware",Style = "Textbox",IsReadOnly = true,TextBoxStyle = "NoBackground",HTextAlign = "Right",VTextAlign = "Center",TextColor = White,Position = { 91, 693 },Size = { 43, 20 },TextFontSize = 16,IsBold = true}
    -- Channel controls
    layout["GlobalGreenState"] = {PrettyName = "Global LED~Green~State",Style = "Button",ButtonStyle = "Toggle",Color = LEDGrn,Position = { 296, 289 },Size = { 45, 45 },Radius = 2,Margin = 2}
    layout["GlobalRedState"] = {PrettyName = "Global LED~Red~State",Style = "Button",ButtonStyle = "Toggle",Color = LEDRed,Position = { 362, 289 },Size = { 45, 45 },Radius = 2,Margin = 2}
    layout["GlobalGreenBrightness"] = {PrettyName = "Global LED~Green~Brightness Fader",Style = "Fader",Position = { 296, 346 },Size = { 45, 18 },Color = { 0, 255, 0 }}
    layout["GlobalRedBrightness"] = {PrettyName = "Global LED~Red~Brightness Fader",Style = "Fader",Position = { 362, 346 },Size = { 45, 18 },Color = { 255, 0, 0 }}
    layout["GlobalGreenBrightnessInput"] = {PrettyName = "Global LED~Green~Brightness Input",Style = "Text",TextBoxStyle = "Normal",Color = LtBlue,Position = { 296, 369 },Size = { 45, 17 },TextFontSize = 10}
    layout["GlobalRedBrightnessInput"] = {PrettyName = "Global LED~Red~Brightness Input",Style = "Text",TextBoxStyle = "Normal",Color = LtBlue,Position = { 362, 369 },Size = { 45, 17 },TextFontSize = 10}
    for i=1,4 do
      layout["PhantomPower "..i] = {PrettyName = string.format("Channel %i~Phantom",i),Style = "Button",ButtonStyle = "Toggle",Color = BtnLtBlue,OffColor = BtnDkBlue,UnlinkOffColor = true,Position = { 121+(i-1)*97, 210 },Size = { 70, 32 },Radius = 2,Margin = 2,TextFontSize = 16}
      layout["GreenState "..i] = {PrettyName = string.format("Channel %i~LED~Green~State",i),Style = "Button",ButtonStyle = "Toggle",Color = LEDGrn,Position = { i*123-7, 434 },Size = { 45, 45 },Radius = 2,Margin = 2}
      layout["GreenBrightness "..i] = {PrettyName = string.format("Channel %i~LED~Green~Brightness Fader",i),Style = "Fader",Position = { i*123-7, 491 },Size = { 45, 18 },Color = { 0, 255, 0 }}
