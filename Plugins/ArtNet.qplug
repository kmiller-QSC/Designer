--[[
  --------------------
  UI LIBRARY FUNCTIONS
  --------------------
]]--
function newLabel(anchor, size, column, row, text, align, bold, textsize, rowSpan, style)
  if rowSpan == nil then rowSpan = 1 end
  if align == nil then align = "Left" end
  if bold == nil then bold = false end
  if textsize == nil then textsize = 12 end
  if style == nil then style = "Normal" end
  return {
    Type = "Label",
    Text = text,
    HTextAlign = align,
    StrokeWidth = 0,
    IsBold = bold,
    TextBoxStyle = style,
    Position = { anchor[1] + (size[1] * column),
                 anchor[2] + (size[2] * row) },
    Size = { size[1] * rowSpan, size[2]},
    TextSize = textsize
  }
end

function newGroupBox(anchor, size, text)
  return{
    Type = "GroupBox",
    Text = text,
    HTextAlign = "Left",
    StrokeWidth = 1,
    CornerRadius = 0,
    Fill = { 0xB3, 0xE0, 0xFF },
    Position = anchor,
    Size = size
  }
end

function setControlAsLabel(anchor, size, column, row, name, rowSpan)
  if rowSpan == nil then rowSpan = 1 end
  return {
    PrettyName = name,
    Style = "Text",
    HTextAlign = "Left",
    Position = { anchor[1] + (size[1] * column),
                 anchor[2] + (size[2] * row) },
    Size = { size[1] * rowSpan, size[2]},
    IsReadOnly = true,
    TextBoxStyle = "NoBackground",
    Color = { 0, 0, 0 }
  }
end

function setButtonLayout2(anchor, size, column, row, name, backgroundCol)
  return {
    PrettyName = name,
    Style = "Button",
    Position = { anchor[1] + (size[1] * column),
                 anchor[2] + (size[2] * row) },
    Size = { size[1], size[2]},
    Legend = name,
    IsReadOnly = false,
    Color = backgroundCol
  }
end

function setControlLayout(anchor, size, column, row, name, type, rowSpan)
  if rowSpan == nil then rowSpan = 1 end
  return {
    PrettyName = name,
    Style = type,
    Position = { anchor[1] + (size[1] * column),
                 anchor[2] + (size[2] * row) },
    Size = { size[1] * rowSpan, size[2]},
    IsReadOnly = false
  }
end

function setControlReadonlyLayout(anchor, size, column, row, name, type, rowSpan)
  if rowSpan == nil then rowSpan = 1 end
